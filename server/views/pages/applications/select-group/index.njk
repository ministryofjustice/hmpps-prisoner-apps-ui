{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% extends "../../../partials/layout.njk" %}

{% set pageTitle = applicationName + " - " + title %}
{% set mainClasses = "app-container govuk-body applications-landing-page" %}

{% block content %}
  <div class="govuk-body govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {{ govukBackLink({
          text: "Back",
          href: "/"
        }) }}

        {% if errorSummary %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorSummary
          }) }}
        {% endif %}

        <span class="govuk-caption-xl">Send a new app</span>
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">{{ title }}</h1>

        <form method="POST" id="select-app-group">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

          {% if errorMessage %}
            <p class="govuk-error-message" id="group-error">
              <span class="govuk-visually-hidden">Error:</span> {{ errorMessage }}
            </p>
          {% endif %}

          <div class="tiles-panel govuk-!-margin-top-0 govuk-!-padding-top-0">
            <div id="app-group-tiles">
              {% for group in groups %}
                <div class="link-tile{{ ' link-tile--selected' if group.checked }}">
                  <button type="submit" name="group" value="{{ group.value }}" class="app-group-tile__button">
                    <img src="{{ group.image }}" alt="" loading="lazy" />
                    <footer class="govuk-!-padding-4 govuk-grid-column-full">
                      <h3 class="govuk-heading-m">{{ group.text }}</h3>
                      <p class="govuk-body">{{ group.description }}</p>
                    </footer>
                  </button>
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="govuk-button-group govuk-!-margin-top-4">
            <a class="govuk-link" href="/log/cancel">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
