{%- from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs -%}
{%- from "govuk/components/summary-list/macro.njk" import govukSummaryList -%}
{%- from "govuk/components/error-summary/macro.njk" import govukErrorSummary -%}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% extends "../../../partials/layout.njk" %}
{% set pageTitle = applicationName + " - " + title %}
{% set mainClasses = "app-container govuk-body applications-landing-page" %}
{% block beforeContent %}
  <div class="govuk-body govuk-width-container">
    {{ govukBreadcrumbs({
      items: [
        {
          text: "Home",
          href: launchpadHome
        },
        {
          text: "Apps",
          href: "/"
        }
      ]
    }) }}
  </div>
{% endblock %}
{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {% if errors and errors.reply %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [
              {
                text: errors.reply.text,
                href: "#reply"
              }
            ]
          }) }}
        {% endif %}
        <h1 class="govuk-heading-xl govuk-!-margin-top-0">{{ title }}</h1>

        {% if isPending %}
          <div class="govuk-inset-text govuk-!-margin-0 guidance-panel">
            <p>You have sent this app and staff will process it as soon as possible.</p>
          </div>
        {% endif %}

        {% set statusRows = [
          {
            key: { text: "Status" },
            value: {
              html: '<strong class="govuk-tag ' + statusClass + '">' + statusLabel + '</strong>'
            }
          }
        ] %}

        {% if isDecisionMade and reason %}
          {% set statusRows = (statusRows.push({
            key: { text: "Reason" },
            value: { text: reason }
          }), statusRows) %}
        {% endif %}

        {{ govukSummaryList({ rows: statusRows }) }}
      
        {% include "./partials/application-details.njk" %}

        {% if isGeneric %}
          {% include "./partials/application-type-generic-details.njk" %}
        {% else %}
          {% include "./partials/" + applicationType + ".njk" %}
        {% endif %}

        {% include "./partials/messages.njk" %}

        {{ govukButton({
          text: "Back to apps home",
          classes: "govuk-button--secondary govuk-!-margin-top-4",
          href: "/"
        }) }}
      </div>
    </div>
  </div>
{% endblock %}
