{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

<h2 class="govuk-heading-m">Emergency credit to add</h2>
{{ govukSummaryList({
  rows: [
    { 
      key: { text: "Amount" }, 
      value: { text: "£" + application.requests[0].amount }        
    },
    {
      key: { text: "Reason" },
      value: { text: application.requests[0].reason }
    }
  ]
}) }}       
