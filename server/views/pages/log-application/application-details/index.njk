{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "./partials/errors.njk" import renderErrorSummary %}


{% extends "../../../partials/layout.njk" %}

{% set pageTitle = applicationName + " - " + title %}
{% set mainClasses = "app-container govuk-body applications-landing-page" %}

{% block content %}
  <div class="govuk-body govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {{ govukBackLink({
          text: "Back",
          href: backLink
        }) }}

        {{ renderErrorSummary(errors) }}

        <span class="govuk-caption-xl">{{ applicationType.name }}</span>
        <h1 class="govuk-heading-xl govuk-!-margin-top-0">{{ title }}</h1>

        <form method="POST" id="log-details">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          {% if isGeneric %}
            {% include "./partials/application-type-generic-details.njk" %}
          {% else %}
            {% include "./partials/" + applicationType.key + ".njk" %}
          {% endif %}

         <div class="govuk-button-group">
            {{ govukButton({
              text: "Continue"
            }) }}

            <a class="govuk-link" href="/log/cancel">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
