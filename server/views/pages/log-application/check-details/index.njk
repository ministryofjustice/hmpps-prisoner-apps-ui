{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% extends "../../../partials/layout.njk" %}

{% set pageTitle = applicationName + " - " + title %}
{% set mainClasses = "app-container govuk-body applications-landing-page" %}

{% block content %}
  <div class="govuk-body govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {{ govukBackLink({
          text: "Back",
          href: backLink
        }) }}

        <span class="govuk-caption-xl">{{ applicationType.name }}</span>
        <h1 class="govuk-heading-xl govuk-!-margin-top-0">Check details</h1>

        {% set summaryListRows = [] %}
        {% for summaryRow in summaryRows %}
          {% set summaryListRows = (summaryListRows.push({
            key: { text: summaryRow.key },
            value: { text: summaryRow.value },
            actions: {
              items: [
                {
                  href: backLink,
                  text: "Change",
                  visuallyHiddenText: summaryRow.key
                }
              ]
            }
          }), summaryListRows) %}
        {% endfor %}

        {{ govukSummaryList({ rows: summaryListRows }) }}

        <form method="POST">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          {{ govukButton({
            text: "Submit application",
            classes: "govuk-button--primary"
          }) }}
        </form>
      </div>
    </div>
  </div>
{% endblock %}
