{% extends "govuk/template.njk" %}
{% from "pfs/components/launchpad-header/macro.njk" import launchpadHeader %}
{% from "pfs/components/launchpad-footer/macro.njk" import launchpadFooter %}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet"/>
{% endblock %}

{% block pageTitle %}{{pageTitle | default(applicationName)}}{% endblock %}

{% block header %}
  {{ launchpadHeader(launchpadHeaderConfig) }}
{% endblock %}

{% block bodyStart %}
{% endblock %}

{% block footer %}
  {{ launchpadFooter(launchpadFooterConfig) }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
{% endblock %}
